# Phase 1 bootstrap certificate.env (used only for initial setup).
# Runtime state lives in:
#   %ProgramData%\simple-acme\settings.json
#   %ProgramData%\simple-acme\*.renewal.json

ACME_PROVIDER=letsencrypt
ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory
ACME_REQUIRES_EAB=0
ACME_KID=
ACME_HMAC_SECRET=
DOMAINS=example.com,www.example.com
TARGET_SYSTEM=rds
TARGET_LOCATION=this-server

# Optional bootstrap values
ACME_ACCOUNT_NAME=
ACME_WACS_PATH=C:\\certificaat\\wacs.exe
ACME_WACS_SOURCE=official-release
ACME_WACS_VERSION=
ACME_WACS_AUTO_UPDATE=0
ACME_WACS_RELEASE_ZIP=
ACME_WACS_RELEASE_SHA256=
ACME_WACS_VERSION_TIMEOUT_SECONDS=90
ACME_REQUIRE_WACS_VERSION_CHECK=0
ACME_CSR_ALGORITHM=ec
ACME_PRIVATEKEY_EXPORTABLE=false

ACME_KEY_TYPE=ec
ACME_EC_CURVE=P-256
ACME_RSA_KEY_SIZE=
ACME_ALLOW_CSR_FALLBACK=0
ACME_WACS_TIMEOUT_SECONDS=300
ACME_WACS_RETRY_ATTEMPTS=1
ACME_WACS_RETRY_DELAY_SECONDS=2
